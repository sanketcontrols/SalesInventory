# Copy to .env in project root for Docker Compose
# cp .env.docker.example .env

# Synology DSM already uses port 5000 — use 5080 (or 3000 / 8080)
APP_PORT=5080
# Synology / host Postgres often uses 5432 — map DB to 5433 on the NAS
DB_HOST_PORT=5433
DB_NAME=billing
DB_USER=postgres
DB_PASSWORD=change-this-strong-password
JWT_SECRET=change-this-to-a-long-random-secret-key
