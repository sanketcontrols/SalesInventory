# Copy to .env in project root for Docker Compose on NAS
# cp .env.docker.example .env

# Synology DSM already uses port 5000 — use 5080
APP_PORT=5080
# Synology / host often uses 5432 — map DB to 5433 on the NAS
DB_HOST_PORT=5433

# IMPORTANT: these must match the password used the FIRST time the db volume was created.
# If login fails with "password rejected", either:
#   A) set DB_PASSWORD below to the OLD password, or
#   B) delete the postgres_data volume and recreate (wipes DB data)
DB_NAME=billing
DB_USER=postgres
DB_PASSWORD=changeme
JWT_SECRET=change-this-secret-in-production

# Auto-reset harsh@gmail.com password to 123456 on each app start (NAS)
RESET_ADMIN_PASSWORD=true
AUTO_FIX_ADMIN=true

# Do NOT put DATABASE_URL (Render) in this file for NAS Docker.
# Compose forces DB_HOST=db and DB_SSL=false for the app container.
